# Self-hosted API proxy — routes to public THORNode/Midgard endpoints
# No API key needed! All data comes from public blockchain endpoints.
NEXT_PUBLIC_MEMOLESS_API=https://swap.arkeomarketplace.com/api/memoless/api/v1
NEXT_PUBLIC_USWAP_API_URL=https://swap.arkeomarketplace.com/api/v1
NEXT_PUBLIC_USWAP_API_KEY=not-needed
NEXT_PUBLIC_BLOCKCHAIR_API_KEY=

# Arkeo Provider Configuration
NEXT_PUBLIC_ARKEO_ENABLED=true
NEXT_PUBLIC_ARKEO_SENTINEL_URL=https://arkeo-provider.liquify.com
